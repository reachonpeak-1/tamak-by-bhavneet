rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product & CMS images: public read, no client writes (uploaded via Admin SDK).
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /content/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
