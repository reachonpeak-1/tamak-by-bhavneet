rules_version = '2';

// All trusted writes go through the Admin SDK (API routes), which BYPASSES these
// rules. The storefront also reads products/content/settings server-side via the
// Admin SDK, so these client rules can stay tight.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public catalog & site content — readable, never client-writable.
    match /products/{id}   { allow read: if true;  allow write: if isAdmin(); }
    match /content/{id}    { allow read: if true;  allow write: if false; }
    match /settings/{id}   { allow read: if true;  allow write: if false; }

    // Coupons must never be enumerable by clients (validated server-side only).
    match /coupons/{code}  { allow read, write: if false; }

    // Orders: created server-side; a user may read their own, admins read all.
    match /orders/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // Per-user profile / saved data.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{doc=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Admin-SDK-only collections.
    match /subscribers/{id} { allow read, write: if false; }
    match /auditLog/{id}    { allow read, write: if false; }
    // Image metadata catalog — all reads/writes go through the Admin SDK in API routes.
    // Client-side access is intentionally blocked so the image catalog stays private.
    match /mediaLibrary/{id} { allow read, write: if false; }

    // Default deny.
    match /{document=**} { allow read, write: if false; }
  }
}
